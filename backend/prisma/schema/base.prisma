generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Pet enums
enum PetSex {
  MACHO
  HEMBRA
}

enum PetSize {
  PEQUENO
  MEDIANO
  GRANDE
}

// Reservation enum
enum ReservationStatus {
  CONFIRMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}
