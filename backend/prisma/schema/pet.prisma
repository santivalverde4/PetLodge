model Pet {
  id                 String        @id @default(uuid())
  nombre             String
  tipo               String
  raza               String
  anos               Int           @default(0)
  meses              Int           @default(0)
  sexo               PetSex
  tamano             PetSize
  estadoVacunacion   String        @default("")
  condicionesMedicas String        @default("")
  numeroVeterinario  String        @default("")
  cuidadosEspeciales String        @default("")
  foto               String?
  isActive           Boolean       @default(true)
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations       Reservation[]
}
